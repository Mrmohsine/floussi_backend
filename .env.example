DATABASE_URL="postgresql://postgres:postgres@localhost:5432/paycheck?schema=public"
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"
PORT=4000
NODE_ENV=development
# Comma-separated web origins allowed by CORS. Native mobile requests usually have no Origin header.
CORS_ORIGINS="http://localhost:8081,http://localhost:19006,http://localhost:19000"
# Optional — required only for the AI chat endpoint. Get one at https://platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Stripe — required only for the upgrade flow. Get test keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
APP_DEEP_LINK_SCHEME=paycheck
# Resend — sends OTP and password-reset emails. Get a key at https://resend.com
RESEND_API_KEY=
EMAIL_FROM=Paycheck <onboarding@resend.dev>
# Google OAuth — create OAuth 2.0 Client IDs in Google Cloud Console.
# Web client ID is the primary audience the backend verifies against;
# iOS client ID is also accepted (the native iOS sheet uses that audience).
GOOGLE_OAUTH_WEB_CLIENT_ID=
GOOGLE_OAUTH_IOS_CLIENT_ID=
# Apple Sign-In — audience is your iOS bundle identifier.
APPLE_BUNDLE_ID=
# Set to 1 once enrolled in the Apple Developer Program and ready to ship.
OAUTH_APPLE_ENABLED=0
# Dev-only: auto-verify newly-registered users when Resend's free tier
# refuses to deliver to non-account-owner addresses. Never enable in prod.
AUTO_VERIFY_ON_SANDBOX_FAILURE=0
