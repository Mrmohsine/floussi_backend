DATABASE_URL="postgresql://postgres:postgres@localhost:5432/paycheck?schema=public"
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"
PORT=4000
NODE_ENV=development
# Comma-separated web origins allowed by CORS. Native mobile requests usually have no Origin header.
CORS_ORIGINS="http://localhost:8081,http://localhost:19006,http://localhost:19000"
# Optional — required only for the AI chat endpoint. Get one at https://platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Stripe — required only for the upgrade flow. Get test keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
APP_DEEP_LINK_SCHEME=paycheck
# Resend — sends OTP and password-reset emails. Get a key at https://resend.com
RESEND_API_KEY=
EMAIL_FROM=Paycheck <onboarding@resend.dev>
