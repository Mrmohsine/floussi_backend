// Paycheck — Prisma schema
// Money is stored as Decimal(12,2) — never use Float for currency.
// Dates are UTC; UI converts to user's local zone.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ──────────────────────────────────────────────────────────────────────
// "Enum" values — kept as constants here for reference. We store these as
// plain String columns and rely on the Zod validators at the route boundary
// to enforce the set.
//
//   PaySchedule:        WEEKLY | BIWEEKLY | TWICE_MONTHLY | MONTHLY
//   CountryCode:        US | EU | JP | GB | CN | AU | CA | CH
//   PaymentMethod:      CASH | DEBIT_CARD | CREDIT_CARD | BANK_TRANSFER
//   ExpenseType:        FIXED_BILL | VARIABLE
//   DebtType:           CREDIT_CARD | STUDENT_LOAN | AUTO_LOAN |
//                       PERSONAL_LOAN | MORTGAGE | MEDICAL | OTHER
//   SavingsGoalType:    EMERGENCY_FUND | VACATION | CAR_DOWN_PAYMENT |
//                       HOUSE_DOWN_PAYMENT | DEBT_PAYOFF | OTHER
//   RecurringFrequency: MONTHLY | WEEKLY | BIWEEKLY | YEARLY
// ──────────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  PRO
  PREMIUM
}

// ──────────────────────────────────────────────────────────────────────
// User
// ──────────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  name            String
  provider        String?
  providerSub     String?
  countryCode     String    @default("US")
  currency        String    @default("USD")
  paySchedule     String    @default("BIWEEKLY")
  plan            Plan      @default(FREE)
  planSince       DateTime  @default(now())
  emailVerified   Boolean   @default(false)
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  budgetMonths   BudgetMonth[]
  userCategories UserCategory[]
  expenses       Expense[]
  incomes        Income[]
  savingsGoals   SavingsGoal[]
  debts          Debt[]
  recurringBills RecurringBill[]
  conversations  Conversation[]
  notifications  Notification[]
  oneTimeCodes   OneTimeCode[]
  plaidItems     PlaidItem[]
  bankTransactions BankTransaction[]

  @@unique([provider, providerSub])
  @@index([providerSub])
}

// One-time codes for email verification + password reset.
// kind = "EMAIL_VERIFY" | "PASSWORD_RESET". 6-digit numeric.
model OneTimeCode {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind       String
  code       String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, kind])
  @@index([expiresAt])
}

// ──────────────────────────────────────────────────────────────────────
// Chat — saved conversations with the AI money coach
// ──────────────────────────────────────────────────────────────────────

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @default("New chat")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]

  @@index([userId, updatedAt])
}

model ChatMessage {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // "user" | "assistant"
  content        String
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// ──────────────────────────────────────────────────────────────────────
// Notifications — persisted smart nudges generated from user data
// ──────────────────────────────────────────────────────────────────────

model Notification {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  monthKey     String // YYYY-MM
  sourceId     String // stable generator id, e.g. debt_high_apr_<debtId>
  tone         String // positive | info | warning | alert
  title        String
  body         String
  actionLabel  String?
  priority     Int
  fingerprint  String?
  aiEnhancedAt DateTime?
  readAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, monthKey, sourceId])
  @@index([userId, monthKey, readAt])
  @@index([userId, createdAt])
}

// ──────────────────────────────────────────────────────────────────────
// Categories — shared catalog + user links
// ──────────────────────────────────────────────────────────────────────

model Category {
  id             String   @id @default(cuid())
  name           String
  normalizedName String   @unique
  icon           String // icon key e.g. "home", "utensils"
  color          String // hex e.g. "#10B981"
  isSystem       Boolean  @default(false)
  createdAt      DateTime @default(now())

  userCategories UserCategory[]
  expenses       Expense[]
  recurringBills RecurringBill[]
}

model UserCategory {
  userId     String
  categoryId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([userId, categoryId])
  @@index([userId])
  @@index([categoryId])
}

// ──────────────────────────────────────────────────────────────────────
// BudgetMonth — one per user per (year, month)
// ──────────────────────────────────────────────────────────────────────

model BudgetMonth {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  year          Int
  month         Int // 1–12
  plannedIncome Decimal
  savingsTarget Decimal  @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  incomes  Income[]
  expenses Expense[]

  @@unique([userId, year, month])
  @@index([userId])
}

// ──────────────────────────────────────────────────────────────────────
// Income — actual paycheck deposits
// ──────────────────────────────────────────────────────────────────────

model Income {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  budgetMonthId String?
  budgetMonth   BudgetMonth? @relation(fields: [budgetMonthId], references: [id], onDelete: SetNull)
  amount        Decimal
  source        String // "Employer", "Side gig", etc.
  receivedAt    DateTime
  note          String?
  createdAt     DateTime     @default(now())

  @@index([userId, receivedAt])
}

// ──────────────────────────────────────────────────────────────────────
// Expense
// ──────────────────────────────────────────────────────────────────────

model Expense {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId      String
  category        Category       @relation(fields: [categoryId], references: [id])
  budgetMonthId   String?
  budgetMonth     BudgetMonth?   @relation(fields: [budgetMonthId], references: [id], onDelete: SetNull)
  amount          Decimal
  date            DateTime
  note            String?
  paymentMethod   String         @default("DEBIT_CARD")
  type            String         @default("VARIABLE")
  // If created from a recurring bill template
  recurringBillId String?
  recurringBill   RecurringBill? @relation(fields: [recurringBillId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId, date])
  @@index([categoryId])
  @@index([budgetMonthId])
}

// ──────────────────────────────────────────────────────────────────────
// Savings goal
// ──────────────────────────────────────────────────────────────────────

model SavingsGoal {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  type         String    @default("OTHER")
  targetAmount Decimal
  savedAmount  Decimal   @default(0)
  targetDate   DateTime?
  icon         String    @default("piggy-bank")
  color        String    @default("#10B981")
  archivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}

// ──────────────────────────────────────────────────────────────────────
// Debt
// ──────────────────────────────────────────────────────────────────────

model Debt {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  type            String    @default("OTHER")
  totalAmount     Decimal
  remainingAmount Decimal
  interestRate    Decimal   @default(0) // APR percent, e.g. 19.990
  minimumPayment  Decimal
  dueDay          Int? // 1–31
  payoffDate      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
}

// ──────────────────────────────────────────────────────────────────────
// Recurring bill (template — produces Expenses each month)
// ──────────────────────────────────────────────────────────────────────

model RecurringBill {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id])
  name          String
  amount        Decimal
  frequency     String   @default("MONTHLY")
  dueDay        Int // 1–31, day of month
  active        Boolean  @default(true)
  paymentMethod String   @default("DEBIT_CARD")
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  expenses Expense[]

  @@index([userId])
}

// ──────────────────────────────────────────────────────────────────────
// Plaid — bank linking. One PlaidItem per linked institution; each item
// owns 1+ PlaidAccounts. BankTransaction stores the raw synced ledger.
// ──────────────────────────────────────────────────────────────────────

model PlaidItem {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Plaid's stable identifier for this Item (institution link).
  plaidItemId     String   @unique
  // The access_token is bearer-equivalent — treat as a secret.
  accessToken     String
  institutionId   String?
  institutionName String?
  // Cursor for /transactions/sync incremental pulls.
  syncCursor      String?
  lastSyncedAt    DateTime?
  status          String   @default("ACTIVE") // ACTIVE | NEEDS_REAUTH | REMOVED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  accounts     PlaidAccount[]
  transactions BankTransaction[]

  @@index([userId])
}

model PlaidAccount {
  id               String  @id @default(cuid())
  itemId           String
  item             PlaidItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  // Plaid's stable per-account id (account_id).
  plaidAccountId   String  @unique
  name             String
  officialName     String?
  mask             String?
  type             String  // depository | credit | loan | investment | other
  subtype          String? // checking | savings | credit card | etc.
  balanceCurrent   Decimal?
  balanceAvailable Decimal?
  isoCurrencyCode  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  transactions BankTransaction[]

  @@index([itemId])
}

model BankTransaction {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId              String
  item                PlaidItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  accountId           String
  account             PlaidAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  // Plaid's stable transaction_id — used for upserts during sync.
  plaidTransactionId  String   @unique
  // Plaid signs amounts positive = money out, negative = money in.
  amount              Decimal
  isoCurrencyCode     String?
  date                DateTime
  authorizedDate      DateTime?
  name                String
  merchantName        String?
  // Personal Finance category from Plaid (PRIMARY label).
  category            String?
  categoryDetailed    String?
  pending             Boolean  @default(false)
  paymentChannel      String?  // online | in store | other
  // If this transaction has been imported into the user's ledger, the
  // linked row id. Set during sync so we never double-import.
  expenseId           String?
  incomeId            String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId, date])
  @@index([accountId, date])
  @@index([itemId])
}
